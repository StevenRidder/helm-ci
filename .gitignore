# macOS
.DS_Store

# Xcode / Swift (for when app code lands)
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
.build/
*.swiftpm/

# Build artifacts
build/
dist/
*.o
*.a

# Charts & weather data — large, license-bound, never commit
*.mbtiles
*.kap
*.000
*.grb
*.grb2
*.grib2
/charts/
/cache/

# Generated design archives can embed local paths; commit expanded assets instead.
docs/design/app-icons/*.zip
docs/Helm Icons/Official Icons/*.zip

# Secrets / API keys (Windy, etc.)
.env
.env.*
# the committed template carries no secrets — keep it tracked
!.env.example
*.key
secrets/

# Editor
.vscode/
.idea/

# Local agent/live-machine coordination. Keep these out of the public repo.
.claude/
AGENTS.md
