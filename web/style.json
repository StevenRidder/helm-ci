{
  "version": 8,
  "name": "Helm — tracer bullet",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "sat": {
      "type": "raster",
      "tileSize": 256,
      "tiles": [
        "https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg"
      ],
      "attribution": "Sentinel-2 cloudless by EOX (CC-BY-4.0)"
    },
    "charts": {
      "type": "raster",
      "tileSize": 256,
      "tiles": [
        "https://tileservice.charts.noaa.gov/tiles/50000_1/{z}/{x}/{y}.png"
      ],
      "attribution": "NOAA ENC (public domain)"
    },
    "enc": {
      "type": "raster",
      "tileSize": 256,
      "minzoom": 10,
      "maxzoom": 17,
      "tiles": [
        "http://127.0.0.1:8082/chart/{z}/{x}/{y}.png"
      ],
      "attribution": "S-52 via OpenCPN (Helm Engine)"
    },
    "depare": {
      "type": "geojson",
      "data": "data/depare.geojson"
    },
    "depcnt": {
      "type": "geojson",
      "data": "data/depcnt.geojson"
    },
    "soundg": {
      "type": "geojson",
      "data": "data/soundg.geojson"
    },
    "route": {
      "type": "geojson",
      "data": "data/route.geojson"
    },
    "wind": {
      "type": "geojson",
      "data": "data/wind_points.geojson"
    },
    "places": {
      "type": "geojson",
      "data": "data/places.geojson",
      "attribution": "(c) OpenStreetMap contributors, ODbL"
    },
    "ais": {
      "type": "geojson",
      "data": "data/ais-sample.geojson"
    }
  },
  "layers": [
    {
      "id": "satellite",
      "type": "raster",
      "source": "sat"
    },
    {
      "id": "charts",
      "type": "raster",
      "source": "charts",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "raster-opacity": 0.85
      }
    },
    {
      "id": "enc-chart",
      "type": "raster",
      "source": "enc",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "raster-opacity": 1.0
      }
    },
    {
      "id": "depare-fill",
      "type": "fill",
      "source": "depare",
      "paint": {
        "fill-color": [
          "interpolate",
          [
            "linear"
          ],
          [
            "coalesce",
            [
              "get",
              "DRVAL1"
            ],
            0
          ],
          0,
          "#a9d6ec",
          5,
          "#bfe2f0",
          10,
          "#d8eef8",
          30,
          "#eef7fc"
        ],
        "fill-opacity": 0.45
      }
    },
    {
      "id": "depcnt-line",
      "type": "line",
      "source": "depcnt",
      "paint": {
        "line-color": "#2f6f8f",
        "line-width": 0.8,
        "line-dasharray": [
          3,
          3
        ],
        "line-opacity": 0.7
      }
    },
    {
      "id": "soundg-text",
      "type": "symbol",
      "source": "soundg",
      "layout": {
        "text-field": [
          "number-format",
          [
            "get",
            "DEPTH"
          ],
          {
            "max-fraction-digits": 0
          }
        ],
        "text-font": [
          "Open Sans Regular"
        ],
        "text-size": 11,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#345",
        "text-halo-color": "#fff",
        "text-halo-width": 1
      }
    },
    {
      "id": "route-line",
      "type": "line",
      "source": "route",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d6219a",
        "line-width": 3
      }
    },
    {
      "id": "wind-arrows",
      "type": "symbol",
      "source": "wind",
      "layout": {
        "text-field": "↑",
        "text-font": [
          "Open Sans Regular"
        ],
        "text-size": 18,
        "text-rotate": [
          "%",
          [
            "+",
            [
              "get",
              "dir_deg"
            ],
            180
          ],
          360
        ],
        "text-rotation-alignment": "map",
        "text-allow-overlap": true
      },
      "paint": {
        "text-color": [
          "interpolate",
          [
            "linear"
          ],
          [
            "get",
            "speed_kn"
          ],
          0,
          "#1aa58c",
          12,
          "#7fae3a",
          20,
          "#d98a1a",
          30,
          "#dd3b3b"
        ],
        "text-opacity": 0.9
      }
    },
    {
      "id": "places-halo",
      "type": "circle",
      "source": "places",
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "circle-radius": 11,
        "circle-color": "rgba(13,19,27,0.74)",
        "circle-stroke-width": 1.2,
        "circle-stroke-color": [
          "match",
          [
            "get",
            "kind"
          ],
          "marina",
          "#5bc0ff",
          "anchorage",
          "#8fd3ff",
          "fuel",
          "#f2b441",
          "dinghy",
          "#5bc0ff",
          "water",
          "#7fd1e0",
          "chandlery",
          "#cdd6e0",
          "rgba(255,255,255,0.13)"
        ],
        "circle-pitch-alignment": "map"
      }
    },
    {
      "id": "places-icon",
      "type": "symbol",
      "source": "places",
      "layout": {
        "visibility": "visible",
        "symbol-sort-key": [
          "match",
          [
            "get",
            "kind"
          ],
          "marina",
          0,
          "fuel",
          1,
          "anchorage",
          2,
          "dinghy",
          3,
          "chandlery",
          4,
          "water",
          5,
          9
        ],
        "text-field": [
          "match",
          [
            "get",
            "kind"
          ],
          "marina",
          "M",
          "anchorage",
          "⚓",
          "fuel",
          "F",
          "dinghy",
          "D",
          "water",
          "W",
          "chandlery",
          "C",
          "•"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 13,
        "text-allow-overlap": true,
        "text-ignore-placement": true,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": [
          "match",
          [
            "get",
            "kind"
          ],
          "marina",
          "#5bc0ff",
          "anchorage",
          "#8fd3ff",
          "fuel",
          "#f2b441",
          "dinghy",
          "#5bc0ff",
          "water",
          "#7fd1e0",
          "chandlery",
          "#cdd6e0",
          "#5bc0ff"
        ],
        "text-halo-color": "rgba(13,19,27,0.9)",
        "text-halo-width": 1.0
      }
    },
    {
      "id": "places-label",
      "type": "symbol",
      "source": "places",
      "minzoom": 12,
      "layout": {
        "visibility": "visible",
        "text-field": [
          "get",
          "name"
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11,
        "text-anchor": "top",
        "text-offset": [
          0,
          1.0
        ],
        "text-optional": true,
        "text-max-width": 9
      },
      "paint": {
        "text-color": "#e8eef5",
        "text-halo-color": "rgba(13,19,27,0.92)",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "ais-vessels",
      "type": "symbol",
      "source": "ais",
      "layout": {
        "visibility": "visible",
        "text-field": "▲",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 15,
        "text-rotate": [
          "get",
          "cog"
        ],
        "text-rotation-alignment": "map",
        "text-allow-overlap": true,
        "text-ignore-placement": true
      },
      "paint": {
        "text-color": [
          "case",
          [
            "<",
            [
              "coalesce",
              [
                "get",
                "cpa"
              ],
              99
            ],
            0.2
          ],
          "#e4564f",
          [
            "<",
            [
              "coalesce",
              [
                "get",
                "cpa"
              ],
              99
            ],
            0.5
          ],
          "#f2b441",
          "#5bc0ff"
        ],
        "text-halo-color": "rgba(13,19,27,0.9)",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "ais-label",
      "type": "symbol",
      "source": "ais",
      "minzoom": 12,
      "layout": {
        "visibility": "visible",
        "text-field": [
          "format",
          [
            "get",
            "name"
          ],
          {
            "font-scale": 1.0
          },
          "\n",
          {},
          [
            "concat",
            [
              "to-string",
              [
                "get",
                "sog"
              ]
            ],
            " kn"
          ],
          {
            "font-scale": 0.85
          }
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11,
        "text-anchor": "left",
        "text-offset": [
          0.9,
          0
        ],
        "text-optional": true
      },
      "paint": {
        "text-color": "#cdd6e0",
        "text-halo-color": "rgba(13,19,27,0.92)",
        "text-halo-width": 1.3
      }
    }
  ],
  "center": [
    -81.77,
    24.52
  ],
  "zoom": 12
}