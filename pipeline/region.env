# Helm tracer-bullet region config. Change BBOX to build for a different area.
# Active region: Fiji — western Viti Levu (live boat location). Open ocean + reefs +
# the Nadi/Vuda shelf, good real bathymetry relief for DEM depth contours.
# (Previous demo region was Key West, FL — see git history to switch back.)

REGION_NAME="fiji-viti-levu"
# bounding box: West,South,East,North (lon/lat, WGS84). DEM depth contours use this box.
BBOX="176.9,-18.2,177.9,-17.2"
MINZOOM=9
MAXZOOM=15

# Tile sources (XYZ templates). Tokens {z}/{x}/{y} are substituted by name.
# NOTE: NOAA raster charts are US-only — no Fiji coverage (the "NOAA chart" layer stays
# empty here; satellite + the engine's S-52 ENC carry the chart). Left for US regions.
SRC_CHART="https://tileservice.charts.noaa.gov/tiles/50000_1/{z}/{x}/{y}.png"
# Sentinel-2 cloudless (EOX) — CC-BY-4.0, GLOBAL (covers Fiji). {z}/{y}/{x} order maps by name.
SRC_SAT="https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg"

# Weather covers a wider box than the DEM so the field fills the screen at any zoom
# (~3 deg around the anchorage; coarse grid is fine — weather varies slowly).
WIND_BBOX="175.9,-19.2,178.9,-16.2"
WIND_NX=20
WIND_NY=20
