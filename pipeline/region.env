# Helm tracer-bullet region config. Change BBOX to build for a different area.
# Default: Key West, FL — US (NOAA ENC, public domain) + clear shallow water + reefs,
# ideal for showing depth-on-satellite.

REGION_NAME="key-west"
# bounding box: West,South,East,North (lon/lat, WGS84)
BBOX="-81.86,24.44,-81.68,24.60"
MINZOOM=9
MAXZOOM=15

# Tile sources (XYZ templates). Tokens {z}/{x}/{y} are substituted by name.
# NOAA raster nautical charts — US public domain.
SRC_CHART="https://tileservice.charts.noaa.gov/tiles/50000_1/{z}/{x}/{y}.png"
# Sentinel-2 cloudless (EOX) — CC-BY-4.0. Note the {z}/{y}/{x} order (still works; tokens map by name).
SRC_SAT="https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg"
