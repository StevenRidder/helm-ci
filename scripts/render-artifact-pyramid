#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MAIN="$ROOT/engine/vulkan/render_artifact_pyramid.cpp"
HDR="$ROOT/engine/vulkan/web_mercator.h"
BIN="${HELM_RENDER_ARTIFACT_PYRAMID_BIN:-${TMPDIR:-/tmp}/helm-render-artifact-pyramid}"
CXX_BIN="${CXX:-c++}"

if [ ! -x "$BIN" ] || [ "$MAIN" -nt "$BIN" ] || [ "$HDR" -nt "$BIN" ]; then
  mkdir -p "$(dirname "$BIN")"
  "$CXX_BIN" -std=c++17 -O2 -Wall -Wextra -pedantic -I "$ROOT/engine/vulkan" "$MAIN" -o "$BIN"
fi

export HELM_ROOT="$ROOT"
exec "$BIN" "$@"
