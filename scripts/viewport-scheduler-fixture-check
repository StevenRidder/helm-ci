#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC=(
  "$ROOT/engine/vulkan/viewport_scheduler.cpp"
  "$ROOT/engine/vulkan/viewport_scheduler_json.cpp"
  "$ROOT/engine/vulkan/viewport_scheduler_fixture_check.cpp"
)
HDR=(
  "$ROOT/engine/vulkan/viewport_scheduler.h"
  "$ROOT/engine/vulkan/viewport_scheduler_json.h"
)
BIN="${HELM_VIEWPORT_SCHEDULER_FIXTURE_CHECK_BIN:-${TMPDIR:-/tmp}/helm-viewport-scheduler-fixture-check}"
CXX_BIN="${CXX:-c++}"

needs_build=0
if [ ! -x "$BIN" ]; then
  needs_build=1
else
  for f in "${SRC[@]}" "${HDR[@]}"; do
    if [ "$f" -nt "$BIN" ]; then
      needs_build=1
      break
    fi
  done
fi

if [ "$needs_build" -eq 1 ]; then
  mkdir -p "$(dirname "$BIN")"
  "$CXX_BIN" -std=c++17 -O2 -Wall -Wextra -pedantic -I "$ROOT/engine/vulkan" "${SRC[@]}" -o "$BIN"
fi

exec "$BIN" "$@"
